generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TicketStatus {
  new
  ai_generated
  pending_review
  approved_sent
  edited_sent
  discarded
  manual
  send_failed
}

enum AuditEventType {
  ticket_ingested
  ticket_updated
  approved_sent
  edited_sent
  discarded
  manual
  send_failed
  login
  logout
  form_minted
  form_submitted
  form_approved_sent
  form_rejected_sent
  form_manual
  form_discarded
}

enum FormType {
  devolucion
}

enum FormStatus {
  pending
  submitted
  approved_sent
  rejected_sent
  manual
  discarded
}

enum ThreadMessageDirection {
  inbound
  outbound
}

enum ThreadMessageSource {
  admin
  webmail
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  passwordHash    String
  createdAt       DateTime         @default(now())
  lastLoginAt     DateTime?
  sessions        Session[]
  auditEvents     AuditEvent[]
  approvedTickets Ticket[]         @relation("TicketApprovedBy")
  approvedForms   FormSubmission[] @relation("FormApprovedBy")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ticket {
  id                    String       @id @default(cuid())
  externalMessageId     String       @unique
  customerEmail         String
  customerName          String?
  subject               String
  receivedAt            DateTime
  source                String       @default("webmail")
  originalText          String
  aiReply               String
  finalReply            String?
  category              String?
  intent                String?
  riskFlags             String?
  escalationRecommended Boolean      @default(false)
  aiConfidence          Float?
  confidenceLabel       String?
  routedTemplateId      String?
  routeSource           String?
  sentiment             String?
  sentimentSource       String?
  requiresReview        Boolean      @default(false)
  caseReasoningJson     Json?
  criticJson            Json?
  status                TicketStatus @default(pending_review)
  approvedByUserId      String?
  sentAt                DateTime?
  providerMessageId     String?
  imapUid               String?
  imapMailbox           String?
  messageId             String?
  inReplyTo             String?
  references            String?
  seenSyncedAt          DateTime?
  answeredSyncedAt      DateTime?
  sentFolderSyncedAt    DateTime?
  webmailSyncError      String?
  sentMessageJson       Json?
  sendError             String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  approvedBy     User?            @relation("TicketApprovedBy", fields: [approvedByUserId], references: [id])
  auditEvents    AuditEvent[]
  forms          FormSubmission[]
  threadMessages ThreadMessage[]

  @@index([status, receivedAt])
  @@index([receivedAt])
  @@index([customerEmail])
  @@index([routedTemplateId, receivedAt])
  @@index([routeSource, receivedAt])
  @@index([sentiment, receivedAt])
  @@index([imapMailbox, imapUid])
  @@index([seenSyncedAt])
  @@index([answeredSyncedAt])
}

model ThreadMessage {
  id                String                 @id @default(cuid())
  customerEmail     String
  customerName      String?
  ticketId          String?
  direction         ThreadMessageDirection
  source            ThreadMessageSource
  subject           String
  text              String
  messageAt         DateTime
  messageId         String?
  imapUid           String?
  imapMailbox       String?
  providerMessageId String?
  rawJson           Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([customerEmail, messageAt])
  @@index([ticketId])
  @@unique([imapMailbox, imapUid])
}

model BlockedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model AuditEvent {
  id           String         @id @default(cuid())
  ticketId     String?
  formId       String?
  userId       String?
  eventType    AuditEventType
  beforeStatus TicketStatus?
  afterStatus  TicketStatus?
  metadataJson Json?
  createdAt    DateTime       @default(now())

  ticket Ticket?         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  form   FormSubmission? @relation(fields: [formId], references: [id], onDelete: Cascade)
  user   User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([formId, createdAt])
  @@index([userId, createdAt])
}

model FormSubmission {
  id       String   @id @default(cuid())
  token    String   @unique
  type     FormType @default(devolucion)
  ticketId String?
  ticket   Ticket?  @relation(fields: [ticketId], references: [id])

  customerEmail String
  orderNumber   String?
  purchaseEmail String?
  reason        String?

  submittedAt DateTime?
  ipAddress   String?
  userAgent   String?

  status           FormStatus @default(pending)
  reviewNotes      String?
  finalReply       String?
  approvedByUserId String?
  approvedBy       User?      @relation("FormApprovedBy", fields: [approvedByUserId], references: [id])
  sentAt           DateTime?
  sendError        String?

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images      FormImage[]
  auditEvents AuditEvent[]

  @@index([status, submittedAt])
  @@index([ticketId])
}

model FormImage {
  id          String         @id @default(cuid())
  formId      String
  form        FormSubmission @relation(fields: [formId], references: [id], onDelete: Cascade)
  filename    String
  storagePath String
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime       @default(now())

  @@index([formId])
}

model PlatformOrder {
  id                String    @id @default(cuid())
  platform          String
  externalOrderId   String
  orderNumber       String?
  currency          String

  processedAt       DateTime
  financialStatus   String
  fulfillmentStatus String?
  cancelledAt       DateTime?
  isTest            Boolean   @default(false)

  subtotal          Decimal   @db.Decimal(12, 2)
  totalTax          Decimal   @db.Decimal(12, 2)
  totalShipping     Decimal   @db.Decimal(12, 2)
  totalDiscounts    Decimal   @db.Decimal(12, 2)
  totalPrice        Decimal   @db.Decimal(12, 2)
  totalRefunded     Decimal   @db.Decimal(12, 2) @default(0)

  totalUnits        Int

  customerEmail     String?
  countryCode       String?
  channel           String?

  rawJson           Json?
  externalUpdatedAt DateTime
  syncedAt          DateTime  @default(now())

  @@unique([platform, externalOrderId])
  @@index([platform, processedAt])
  @@index([processedAt])
  @@index([customerEmail, processedAt])
}

model PlatformFinancialTransaction {
  id                    String   @id @default(cuid())
  platform              String
  provider              String
  externalTransactionId String
  externalOrderId       String?
  orderNumber           String?
  currency              String

  grossAmount           Decimal  @db.Decimal(12, 2)
  feeAmount             Decimal  @db.Decimal(12, 2)
  netAmount             Decimal  @db.Decimal(12, 2)

  transactionType       String?
  transactionStatus     String?
  postedAt              DateTime

  rawJson               Json?
  syncedAt              DateTime @default(now())

  @@unique([provider, externalTransactionId])
  @@index([platform, postedAt])
  @@index([provider, postedAt])
  @@index([externalOrderId])
}

model PlatformSyncState {
  id             String    @id @default(cuid())
  platform       String    @unique
  lastUpdatedAt  DateTime?
  lastExternalId String?
  lastSyncRunAt  DateTime?
  lastSyncStatus String?
  lastSyncError  String?
  ordersImported Int       @default(0)
}

model SupportApprovedResponse {
  id               String   @id @default(cuid())
  caseId           String   @unique @map("case_id")
  family           String
  subintent        String
  customerExample  String   @map("customer_example")
  approvedResponse String   @map("approved_response")
  mustInclude      Json?    @map("must_include")
  mustNotInclude   Json?    @map("must_not_include")
  status           String
  priority         Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([status, family, subintent])
  @@map("support_approved_responses")
}
