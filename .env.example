# Shopify backfill script through n8n Shopify credential proxy
N8N_SHOPIFY_ORDERS_PROXY_WEBHOOK_URL=https://chiclove-n8n.lvgraq.easypanel.host/webhook/shopify-orders-page
N8N_SHOPIFY_ORDERS_PROXY_SECRET=

# Lookup de pedidos Shopify EN VIVO (fallback del subscription_order_context, via n8n).
# Si falta cualquiera de estas, el fallback en vivo queda inactivo (fail-open) y solo
# se usa la BD sincronizada. El secret reutiliza review_admin_send_secret de n8n.
N8N_SHOPIFY_ORDER_LOOKUP_WEBHOOK_URL=https://chiclove-n8n.lvgraq.easypanel.host/webhook/shopify-order-lookup
N8N_SHOPIFY_ORDER_LOOKUP_SECRET=
N8N_SHOPIFY_LOOKUP_TIMEOUT_MS=2500
SHOPIFY_BACKFILL_CREATED_AT_MIN=2026-01-01T00:00:00.000Z
SHOPIFY_BACKFILL_CURSOR_PLATFORM=shopify_backfill_2026
SHOPIFY_BACKFILL_MAX_PAGES=0
SHOPIFY_BACKFILL_PAGE_DELAY_MS=600
SHOPIFY_BACKFILL_DB_CHUNK_SIZE=50
SHOPIFY_BACKFILL_DRY_RUN=false
SHOPIFY_BACKFILL_INCLUDE_RAW_JSON=false

# Forms / uploads
FORM_UPLOADS_ROOT=/data/form-uploads
FORM_UPLOAD_MAX_BYTES=5242880
FORM_UPLOAD_MAX_FILES=3
